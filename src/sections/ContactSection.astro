---
    import { Mail } from "@lucide/astro";
    import { Phone } from "@lucide/astro";
    import { MapPin } from "@lucide/astro";
    import Facebook from "../assets/icons/Facebook.astro";
    import Whatsapp from "../assets/icons/Whatsapp.astro";
---

<section class="bg-emerald-950 mt-0" id="contact">
    <div class="wrapper">
        <div class="flex flex-col gap-4 md:gap-6">

            <h2 class="text-3xl md:text-6xl text-white">
                Entrons en contact
            </h2>

            <p class="text-base md:text-lg text-emerald-50 max-w-2xl">
                Une question, une proposition de partenariat, un projet ou une envie de contribuer ? Notre équipe est à votre écoute pour échanger et construire ensemble des solutions adaptées.
            </p>

            <div class="flex flex-col gap-4 text-emerald-50">
                <a href="tel:+22378787878" class="flex items-center gap-2">
                    <Phone />
                    <span class="text-emerald-50">+223 78 78 78 78</span>
                </a>

                <a href="mailto:contact@ong.org" class="flex items-center gap-2">
                    <Mail />
                    <span class="text-emerald-50">contact@ong.org</span>
                </a>

                <address class="flex items-center gap-2 not-italic">
                    <MapPin />
                    <span class="text-emerald-50">Bamako, Mali</span>
                </address>
            </div>

            <div class="flex gap-4 items-center">
                <a href="#" class="w-8 fill-[#0866FF]">
                    <Facebook />
                </a>

                <a href="#" class="w-8 fill-[#25D366]">
                    <Whatsapp />
                </a>
            </div>
        </div>

        <form class="flex flex-col gap-6 bg-white p-6 md:p-8 rounded-xl">

            <div class="flex flex-col gap-1">
                <label for="name">Nom</label>
                <input type="text" name="name" id="name" placeholder="Votre nom">
            </div>

            <div class="flex flex-col gap-1">
                <label for="email">Email</label>
                <input type="email" name="email" id="email" placeholder="Votre email">
            </div>

            <div class="flex flex-col gap-1">
                <label for="wish">Je souhaite</label>
                <select name="wish" id="wish">
                    <option value="partnership">Proposer un partenariat</option>
                    <option value="donation">Faire un don</option>
                    <option value="volunteer">Devenir bénévole</option>
                    <option value="project">Participer à un projet</option>
                    <option value="information">Obtenir des informations</option>
                </select>
            </div>

            <div class="flex flex-col gap-1">
                <label for="message">Message</label>
                <textarea name="message" id="message" rows="5" placeholder="Décrivez votre demande..."></textarea>
            </div>

            <button type="submit" class="btn-primary">
                Envoyer le message
            </button>
        </form>
    </div>
</section>

<style>
    .wrapper {
        gap: 4rem;
        display: grid;
        align-items: center;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
    }
</style>